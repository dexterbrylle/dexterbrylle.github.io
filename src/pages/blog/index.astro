---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const formatDate = (date: Date) =>
  new Intl.DateTimeFormat("en", {
    month: "long",
    day: "numeric",
    year: "numeric",
  }).format(date);
---

<BaseLayout
  title="Technical Blog | SRE, Cloud Infrastructure & DevOps | Dexter Brylle"
  description="Notes on site reliability, security, infrastructure, and building dependable systems."
>
  <section class="page-heading" aria-labelledby="writing-title">
    <p class="kicker">Archive</p>
    <h1 id="writing-title">Writing</h1>
  </section>

  <section class="post-list" aria-label="Blog posts">
    {
      posts.map((post) => (
        <article class="post-item">
          <div class="post-meta">
            <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
            <span>{post.data.tags.join(" / ")}</span>
          </div>
          <h2>
            <a href={`/blog/${post.id.replace(/\.md$/, "")}/`}>{post.data.title}</a>
          </h2>
          <p>{post.data.description}</p>
        </article>
      ))
    }
  </section>
</BaseLayout>
